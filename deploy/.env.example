# Copy to .env on the host (chmod 600) and fill in. Never commit the real .env.
#
# CI rewrites STRATEGON_VERSION on every tagged deploy; everything else is
# managed by hand on the server.

# Image tag to run. Set by CI to the released git tag (e.g. v0.1.0).
STRATEGON_VERSION=latest

# Dedicated database on the shared Postgres host.
STRATEGON_DB_DSN=postgresql://USER:PASSWORD@HOST:5432/strategon

# HMAC key for session cookies. Generate with: openssl rand -hex 32
# Rotating this invalidates every logged-in session.
SESSION_SECRET=

# Discord OAuth application credentials.
# The redirect URI https://s7n.lynkora.com/auth/callback must be registered in
# the Discord Developer Portal or login fails with invalid_redirect_uri.
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Only members of this guild may log in. The control plane has flat
# authorization, so leaving this empty lets any Discord account operate it.
DISCORD_GUILD_ID=
