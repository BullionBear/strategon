# Copy to .env on the host (chmod 600) and fill in. Never commit the real .env.
#
# CI rewrites STRATEGON_VERSION on every tagged deploy; everything else is
# managed by hand on the server.

# Image tag to run. Set by CI to the released git tag (e.g. v0.1.0).
STRATEGON_VERSION=latest

# Dedicated database on the shared Postgres host.
STRATEGON_DB_DSN=postgresql://USER:PASSWORD@HOST:5432/strategon

# HMAC key for session cookies. Generate with: openssl rand -hex 32
# Rotating this invalidates every logged-in session.
SESSION_SECRET=

# Discord OAuth application credentials.
# The redirect URI https://s7n.lynkora.com/auth/callback must be registered in
# the Discord Developer Portal or login fails with invalid_redirect_uri.
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Only members of this guild may log in. The control plane has flat
# authorization, so leaving this empty lets any Discord account operate it.
DISCORD_GUILD_ID=

# S3-compatible object store (SeaweedFS) backing authenticated artifact
# delivery (v0.2.6+). Optional: leave STRATEGON_S3_ENDPOINT blank to disable —
# the control plane falls back to unauthenticated http(s)/file sources only.
#
# This one endpoint is used both for the control plane's own PutObject
# (registration-time ingest) and to sign the GET URLs handed to remote agents
# via ResolveArtifactSource. Agents run on other machines, not this host's
# Docker network, so the endpoint must be a URL *they* can resolve — prefer a
# public (or Tailscale-reachable) hostname over an internal docker-network
# alias even when the control plane itself could reach S3 that way.
STRATEGON_S3_ENDPOINT=https://s3.example.com
STRATEGON_S3_BUCKET=strategon-artifacts
STRATEGON_S3_REGION=us-east-1

# Read straight from the environment (STRATEGON_S3_ACCESS_KEY/SECRET_KEY)
# rather than passed as --s3-access-key/--s3-secret-key flags, so the
# credentials never show up in `docker inspect` or a process listing.
STRATEGON_S3_ACCESS_KEY=
STRATEGON_S3_SECRET_KEY=
