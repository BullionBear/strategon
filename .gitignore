# Binaries
/bin/
*.exe
*.test
*.out

# Go workspace
go.work
go.work.sum

# Editor / OS
.DS_Store
*.swp

# Local runtime artifacts (strategy release trees created during tests/runs)
/tmp/strategon-*

# Local mTLS material from strategon-ca (never commit private keys)
/ca/
/certs/

# Deployment credentials (Hostinger token, deploy keys) — never commit
/credentials/

# Frontend build output copied in for //go:embed; regenerated by `make web-build`.
# The .gitkeep stays so the embed directive still compiles on a fresh checkout.
/internal/webassets/dist/*
!/internal/webassets/dist/.gitkeep

# Frontend
web/node_modules/
web/.svelte-kit/
web/build/
web/.env
web/.env.*
!web/.env.example
# pnpm content-addressable store if created under the repo root
.pnpm-store/

# Cached release assets fetched by deploy/install-agent.sh
/.cache/

# Seeding
/examples/
